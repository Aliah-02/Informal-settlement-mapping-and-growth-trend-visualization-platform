# DarInformal Environment Configuration
# Copy to .env and adjust values for your deployment

# PostgreSQL / PostGIS
POSTGRES_DB=darinformal
POSTGRES_USER=darinformal
POSTGRES_PASSWORD=change_me_in_production

# FastAPI
DEBUG=false
DATABASE_URL=postgresql+asyncpg://darinformal:change_me_in_production@localhost:5432/darinformal
DATABASE_URL_SYNC=postgresql://darinformal:change_me_in_production@localhost:5432/darinformal

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000"]

# Google Earth Engine (for data generation scripts)
# GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY_PATH=/path/to/gee-key.json
# GEE_PROJECT_ID=your-gee-project-id
