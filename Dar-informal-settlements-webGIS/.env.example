# DarInformal Environment Configuration
# Copy to .env:  cp .env.example .env

# ── PostgreSQL / PostGIS ──────────────────────────────────────────────────────
POSTGRES_DB=darinformal
POSTGRES_USER=darinformal
POSTGRES_PASSWORD=darinformal
POSTGRES_PORT=5432

# ── FastAPI Backend ───────────────────────────────────────────────────────────
API_PORT=8000
DEBUG=false
USE_POSTGIS=true

DATABASE_URL=postgresql+asyncpg://darinformal:darinformal@localhost:5432/darinformal
DATABASE_URL_SYNC=postgresql://darinformal:darinformal@localhost:5432/darinformal

# ── GeoServer ─────────────────────────────────────────────────────────────────
GEOSERVER_PORT=8080
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver
GEOSERVER_PUBLIC_URL=/geoserver
GEOSERVER_WORKSPACE=darinformal
GEOSERVER_LAYER=settlements

# ── Nginx / Frontend ──────────────────────────────────────────────────────────
HTTP_PORT=80
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000"]

# ── Google Earth Engine (optional — for data generation) ─────────────────────
# GEE_SERVICE_ACCOUNT=your-sa@project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY_PATH=/path/to/gee-key.json
